<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sameer Mushtaq Tantray</title>

<script src="https://cdn.tailwindcss.com"></script>

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">

<style>

@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap');

:root{
    --bg:#030014;
    --red:#ff003c;
    --red2:#ff335f;
    --card:rgba(255,255,255,0.03);
}

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:var(--bg);
    color:white;
    font-family:'Plus Jakarta Sans',sans-serif;
    overflow-x:hidden;
}

/* BACKGROUND */

body::before{
    content:'';
    position:fixed;
    inset:0;
    background:
        radial-gradient(circle at top left,
        rgba(255,0,60,0.12),
        transparent 40%);
    pointer-events:none;
}

/* NAVBAR */

.navbar{
    position:fixed;
    top:0;
    width:100%;
    z-index:100;
    background:rgba(0,0,0,0.55);
    backdrop-filter:blur(18px);
    border-bottom:1px solid rgba(255,255,255,0.05);
}

.nav-inner{
    max-width:1400px;
    margin:auto;
    padding:18px 40px;
    display:flex;
    align-items:center;
    justify-content:space-between;
}

.logo{
    font-size:34px;
    font-weight:800;
    letter-spacing:-2px;
}

.logo span{
    color:var(--red);
}

.nav-links{
    display:flex;
    gap:40px;
}

.nav-links a{
    color:#d4d4d8;
    text-decoration:none;
    font-size:14px;
    font-weight:600;
    transition:.3s;
}

.nav-links a:hover{
    color:var(--red);
}

/* HERO */

.hero{
    min-height:100vh;
    display:grid;
    grid-template-columns:1fr 1fr;
    align-items:center;
    gap:60px;
    max-width:1400px;
    margin:auto;
    padding:140px 40px 80px;
}

.hero-left{
    z-index:2;
}

.tag{
    display:inline-flex;
    align-items:center;
    gap:10px;
    border:1px solid rgba(255,0,60,0.5);
    padding:10px 20px;
    border-radius:999px;
    margin-bottom:30px;
    font-size:13px;
    color:#e4e4e7;
}

.tag .dot{
    width:10px;
    height:10px;
    border-radius:50%;
    background:var(--red);
    box-shadow:0 0 15px var(--red);
}

.hero h1{
    font-size:90px;
    line-height:0.95;
    font-weight:800;
    margin-bottom:25px;
}

.hero h1 span{
    color:var(--red);
}

.hero p{
    max-width:700px;
    color:#a1a1aa;
    line-height:1.9;
    font-size:19px;
}

.buttons{
    margin-top:40px;
    display:flex;
    gap:20px;
}

.btn{
    padding:18px 34px;
    border-radius:18px;
    text-decoration:none;
    font-weight:700;
    transition:.3s;
}

.btn-primary{
    background:linear-gradient(135deg,var(--red),#ff0048);
    color:white;
    box-shadow:0 0 35px rgba(255,0,60,0.35);
}

.btn-primary:hover{
    transform:translateY(-4px);
}

.btn-outline{
    border:1px solid rgba(255,255,255,0.15);
    color:white;
}

/* SOCIALS */

.socials{
    display:flex;
    gap:18px;
    margin-top:50px;
}

.socials a{
    width:58px;
    height:58px;
    border-radius:18px;
    display:flex;
    align-items:center;
    justify-content:center;
    border:1px solid rgba(255,255,255,0.08);
    color:white;
    font-size:22px;
    transition:.3s;
    text-decoration:none;
    background:rgba(255,255,255,0.02);
}

.socials a:hover{
    border-color:var(--red);
    box-shadow:0 0 25px rgba(255,0,60,0.4);
    transform:translateY(-4px);
}

/* HERO RIGHT */

.hero-right{
    display:flex;
    justify-content:center;
    position:relative;
}

/* LIGHTNING FRAME */

.neon-border-flow{
    position:relative;
    display:inline-block;
    padding:10px;
    border-radius:42px;
    overflow:hidden;
}

/* ELECTRIC LIGHTNING */

.neon-border-flow::before{
    content:"";
    position:absolute;
    inset:-250%;

    background:
    conic-gradient(
        from 0deg,
        transparent 0deg,
        #ffffff 20deg,
        #ffffff 40deg,
        transparent 60deg,
        transparent 100deg,
        #ffffff 120deg,
        #ffffff 150deg,
        transparent 170deg,
        transparent 220deg,
        #ffffff 260deg,
        transparent 300deg,
        #ffffff 340deg,
        transparent 360deg
    );

    animation:rotateEnergy 2s linear infinite;

    filter:
        blur(18px)
        drop-shadow(0 0 25px #ffffff)
        drop-shadow(0 0 55px #ffffff);

}

/* INNER BG */

.neon-border-flow::after{
    content:"";
    position:absolute;
    inset:10px;
    background:#050505;
    border-radius:36px;
    z-index:1;
}

/* PROFILE IMAGE */

.my-photo{
    width:520px;
    height:520px;
    object-fit:cover;
    border-radius:34px;
    position:relative;
    z-index:2;

    animation:pulse 2s ease-in-out infinite;
}

@keyframes rotateEnergy{
    100%{
        transform:rotate(360deg);
    }
}

@keyframes pulse{

    0%,100%{
        box-shadow:
        0 0 25px rgba(255,255,255,0.4),
        0 0 60px rgba(255,255,255,0.25);
    }

    50%{
        box-shadow:
        0 0 45px rgba(255,255,255,0.9),
        0 0 100px rgba(255,255,255,0.4);
    }
}

/* WATERMARK */

.watermark{
    position:absolute;
    left:50%;
    top:50%;
    transform:translate(-50%,-50%);
    font-size:22rem;
    font-weight:800;
    color:rgba(255,255,255,0.03);
    pointer-events:none;
    z-index:0;
}

/* CARDS */

.cards{
    max-width:1400px;
    margin:auto;
    padding:0 40px 100px;
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:30px;
}

.card{
    background:var(--card);
    border:1px solid rgba(255,255,255,0.05);
    border-radius:30px;
    padding:35px;
    transition:.3s;
}

.card:hover{
    transform:translateY(-8px);
    border-color:rgba(255,0,60,0.4);
    box-shadow:0 0 40px rgba(255,0,60,0.15);
}

.card h3{
    font-size:28px;
    margin-bottom:30px;
}

.card-item{
    display:flex;
    gap:20px;
    margin-bottom:30px;
}

.card-item i{
    color:var(--red);
    font-size:24px;
    margin-top:5px;
}

.card-item h4{
    margin-bottom:8px;
}

.card-item p{
    color:#a1a1aa;
    line-height:1.7;
    font-size:14px;
}

/* TECH GRID */

.tech-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:30px;
    text-align:center;
}

.tech-grid div{
    font-size:14px;
}

.tech-grid i{
    font-size:44px;
    margin-bottom:10px;
    color:var(--red);
}

/* RESPONSIVE */

@media(max-width:1100px){

.hero{
    grid-template-columns:1fr;
    text-align:center;
}

.hero p{
    margin:auto;
}

.buttons{
    justify-content:center;
}

.socials{
    justify-content:center;
}

.hero h1{
    font-size:65px;
}

.cards{
    grid-template-columns:1fr;
}

.my-photo{
    width:400px;
    height:400px;
}

}

@media(max-width:700px){

.nav-links{
    display:none;
}

.hero{
    padding:120px 20px 60px;
}

.cards{
    padding:0 20px 80px;
}

.hero h1{
    font-size:48px;
}

.my-photo{
    width:320px;
    height:320px;
}

.watermark{
    font-size:10rem;
}

}

</style>
</head>

